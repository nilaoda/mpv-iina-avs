diff --git a/configure b/configure
index 1759694..dd39b66 100755
--- a/configure
+++ b/configure
@@ -291,6 +291,7 @@ External library support:
                            if openssl, gnutls or mbedtls is not used [no]
   --enable-libtorch        enable Torch as one DNN backend [no]
   --enable-libtwolame      enable MP2 encoding via libtwolame [no]
+  --enable-libarcdav3a     enable AV3A decoding via ArcVideo AV3A [no]
   --enable-libuavs3d       enable AVS3 decoding via libuavs3d [no]
   --enable-libv4l2         enable libv4l2/v4l-utils [no]
   --enable-libvidstab      enable video stabilization using vid.stab [no]
@@ -2096,6 +2097,7 @@ EXTERNAL_LIBRARY_LIST="
     libtls
     libtorch
     libtwolame
+    libarcdav3a
     libuavs3d
     libv4l2
     libvmaf
@@ -3816,6 +3818,7 @@ libsvtjpegxs_decoder_deps="libsvtjpegxs"
 libsvtav1_encoder_select="dovi_rpuenc"
 libtheora_encoder_deps="libtheora"
 libtwolame_encoder_deps="libtwolame"
+libarcdav3a_decoder_deps="libarcdav3a"
 libuavs3d_decoder_deps="libuavs3d"
 libvo_amrwbenc_encoder_deps="libvo_amrwbenc"
 libvorbis_decoder_deps="libvorbis"
@@ -7385,6 +7388,7 @@ enabled libtorch          && check_cxxflags -std=c++17 && require_cxx libtorch t
 enabled libtwolame        && require libtwolame twolame.h twolame_init -ltwolame &&
                              { check_lib libtwolame twolame.h twolame_encode_buffer_float32_interleaved -ltwolame ||
                                die "ERROR: libtwolame must be installed and version must be >= 0.3.10"; }
+enabled libarcdav3a       && require libarcdav3a "libavcodec/arcdav3a.h" avs3_create_decoder -lAVS3AudioDec -lav3a_binaural_render $libm_extralibs $pthreads_extralibs -lc++
 enabled libuavs3d         && require_pkg_config libuavs3d "uavs3d >= 1.1.41" uavs3d.h uavs3d_decode
 enabled libv4l2           && require_pkg_config libv4l2 libv4l2 libv4l2.h v4l2_ioctl
 enabled libvidstab        && require_pkg_config libvidstab "vidstab >= 0.98" vid.stab/libvidstab.h vsMotionDetectInit
