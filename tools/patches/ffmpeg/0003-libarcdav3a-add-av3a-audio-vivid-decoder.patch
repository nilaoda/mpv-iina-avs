+#ifndef IMPR_MIX_BIT_ALLOC
+#define NBITS_MC_RATIO                      4                       // nbits for MC bit allocation ratio
+#else
+#define NBITS_MC_RATIO                      6                       // nbits for MC bit allocation ratio
