diff --git a/libavcodec/libuavs3d.c b/libavcodec/libuavs3d.c
index 45958f1..f6d1ee5 100644
--- a/libavcodec/libuavs3d.c
+++ b/libavcodec/libuavs3d.c
@@ -28,6 +28,7 @@
 #include "libavutil/intreadwrite.h"
 #include "libavutil/opt.h"
 #if defined(__APPLE__) && (defined(__aarch64__) || defined(__arm64__))
+#include <pthread.h>
 #include <sys/sysctl.h>
 #endif
 #include "avcodec.h"
@@ -51,15 +52,10 @@ static int libuavs3d_default_threads(AVCodecContext *avctx)
 #if defined(__APPLE__) && (defined(__aarch64__) || defined(__arm64__))
     if (avctx->thread_count <= 0) {
         int perf_cores = 0;
-        int eff_cores = 0;
         size_t len = sizeof(perf_cores);
 
         if (sysctlbyname("hw.perflevel0.physicalcpu", &perf_cores, &len, NULL, 0) == 0 && perf_cores > 0) {
-            len = sizeof(eff_cores);
-            if (sysctlbyname("hw.perflevel1.physicalcpu", &eff_cores, &len, NULL, 0) != 0 || eff_cores < 0) {
-                eff_cores = 0;
-            }
-            threads = perf_cores + FFMIN(eff_cores, 2);
+            threads = perf_cores;
         }
     }
 #endif
@@ -67,6 +63,35 @@ static int libuavs3d_default_threads(AVCodecContext *avctx)
     return av_clip(threads, 1, 32);
 }
 
+static int libuavs3d_perf_cores(void)
+{
+#if defined(__APPLE__) && (defined(__aarch64__) || defined(__arm64__))
+    static int cached = -1;
+
+    if (cached < 0) {
+        int value = 0;
+        size_t len = sizeof(value);
+
+        cached = (sysctlbyname("hw.perflevel0.physicalcpu", &value, &len, NULL, 0) == 0 && value > 0) ? value : 0;
+    }
+
+    return cached;
+#else
+    return 0;
+#endif
+}
+
+static void libuavs3d_set_decode_qos(AVCodecContext *avctx, int frame_threads)
+{
+#if defined(__APPLE__) && (defined(__aarch64__) || defined(__arm64__)) && defined(QOS_CLASS_USER_INITIATED)
+    int perf_cores = libuavs3d_perf_cores();
+
+    if (avctx->thread_count <= 0 && frame_threads > 1 && perf_cores > 0 && frame_threads <= perf_cores) {
+        pthread_set_qos_class_self_np(QOS_CLASS_USER_INITIATED, 0);
+    }
+#endif
+}
+
 #define UAVS3D_CHECK_START_CODE(data_ptr, PIC_START_CODE) \
         (AV_RL32(data_ptr) != (PIC_START_CODE << 24) + AVS3_NAL_START_CODE)
 static int uavs3d_find_next_start_code(const unsigned char *bs_data, int bs_len, int *left)
@@ -217,6 +242,7 @@ static av_cold int libuavs3d_init(AVCodecContext *avctx)
     uavs3d_cfg_t cdsc;
 
     cdsc.frm_threads = libuavs3d_default_threads(avctx);
+    h->frame_threads = cdsc.frm_threads;
     cdsc.check_md5 = 0;
     h->dec_handle = uavs3d_create(&cdsc, uavs3d_output_callback, NULL);
     h->got_seqhdr = 0;
@@ -265,6 +291,8 @@ static int libuavs3d_decode_frame(AVCodecContext *avctx, AVFrame *frm,
     int left_bytes;
     int ret, finish = 0;
 
+    libuavs3d_set_decode_qos(avctx, h->frame_threads);
+
     *got_frame = 0;
     frm->pts = -1;
     frm->pict_type = AV_PICTURE_TYPE_NONE;
