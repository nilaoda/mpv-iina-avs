diff --git a/libavcodec/libuavs3d.c b/libavcodec/libuavs3d.c
index 53b5faa..eca744c 100644
--- a/libavcodec/libuavs3d.c
+++ b/libavcodec/libuavs3d.c
@@ -27,6 +27,9 @@
 #include "libavutil/imgutils.h"
 #include "libavutil/intreadwrite.h"
 #include "libavutil/opt.h"
+#if defined(__APPLE__) && (defined(__aarch64__) || defined(__arm64__))
+#include <sys/sysctl.h>
+#endif
 #include "avcodec.h"
 #include "avs3.h"
 #include "codec_internal.h"
@@ -41,6 +44,29 @@ typedef struct uavs3d_context {
     uavs3d_io_frm_t  dec_frame;
 } uavs3d_context;
 
+static int libuavs3d_default_threads(AVCodecContext *avctx)
+{
+    int threads = avctx->thread_count > 0 ? avctx->thread_count : av_cpu_count();
+
+#if defined(__APPLE__) && (defined(__aarch64__) || defined(__arm64__))
+    if (avctx->thread_count <= 0) {
+        int perf_cores = 0;
+        int eff_cores = 0;
+        size_t len = sizeof(perf_cores);
+
+        if (sysctlbyname("hw.perflevel0.physicalcpu", &perf_cores, &len, NULL, 0) == 0 && perf_cores > 0) {
+            len = sizeof(eff_cores);
+            if (sysctlbyname("hw.perflevel1.physicalcpu", &eff_cores, &len, NULL, 0) != 0 || eff_cores < 0) {
+                eff_cores = 0;
+            }
+            threads = perf_cores + FFMIN(eff_cores, 2);
+        }
+    }
+#endif
+
+    return av_clip(threads, 1, 32);
+}
+
 #define UAVS3D_CHECK_START_CODE(data_ptr, PIC_START_CODE) \
         (AV_RL32(data_ptr) != (PIC_START_CODE << 24) + AVS3_NAL_START_CODE)
 static int uavs3d_find_next_start_code(const unsigned char *bs_data, int bs_len, int *left)
@@ -111,7 +137,7 @@ static av_cold int libuavs3d_init(AVCodecContext *avctx)
     uavs3d_context *h = avctx->priv_data;
     uavs3d_cfg_t cdsc;
 
-    cdsc.frm_threads = avctx->thread_count > 0 ? avctx->thread_count : av_cpu_count();
+    cdsc.frm_threads = libuavs3d_default_threads(avctx);
     cdsc.check_md5 = 0;
     h->dec_handle = uavs3d_create(&cdsc, uavs3d_output_callback, NULL);
     h->got_seqhdr = 0;
