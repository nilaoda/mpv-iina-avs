+bool pl_video_set_icc_profile(struct pl_video *p, const void *data, size_t size)
+{
+    if (!p)
+        return false;
+
+    struct pl_icc_profile profile = {
+        .data = data,
+        .len = size,
+    };
+    pl_icc_profile_compute_signature(&profile);
+    return pl_icc_update(p->pllog, &p->icc_profile, &profile, &p->icc_params);
+}
+
+static struct vt_texture_pool_entry *acquire_vt_texture_pool_entry(struct pl_video *p)
+{
+    if (!p)
+        return NULL;
+
+    for (int i = 0; i < p->num_vt_texture_pool; i++) {
+        if (!p->vt_texture_pool[i].in_use) {
+            p->vt_texture_pool[i].in_use = true;
+            return &p->vt_texture_pool[i];
+        }
+    }
+
+    MP_TARRAY_GROW(p, p->vt_texture_pool, p->num_vt_texture_pool);
+    struct vt_texture_pool_entry *entry =
+        &p->vt_texture_pool[p->num_vt_texture_pool++];
+    *entry = (struct vt_texture_pool_entry){ .in_use = true };
+    return entry;
+}
+
+static void release_vt_texture_pool_entry(struct vt_texture_pool_entry *entry)
+{
+    if (entry)
+        entry->in_use = false;
+}
+
+static struct mp_image *download_hw_frame_for_upload(struct pl_video *p,
+                                                     struct mp_image *mpi)
+{
+    if (!mpi || !IMGFMT_IS_HWACCEL(mpi->imgfmt))
+        return mpi;
+
+    struct mp_image *sw = mp_image_hw_download(mpi, NULL);
+    if (!sw && p && p->log) {
+        mp_msg(p->log, MSGL_ERR,
+               "gpu-next: failed to download hw frame (%s, subfmt=%s)\n",
+               mp_imgfmt_to_name(mpi->imgfmt),
+               mp_imgfmt_to_name(mpi->params.hw_subfmt));
+    }
+    return sw;
+}
+
+#if HAVE_GL && defined(PL_HAVE_OPENGL) && (HAVE_VIDEOTOOLBOX_GL || HAVE_IOS_GL)
+static bool videotoolbox_subfmt_to_gl(enum mp_imgfmt imgfmt, int plane,
+                                      GLint *out_iformat, GLenum *out_format,
+                                      GLenum *out_type)
+{
+    switch (imgfmt) {
+    case IMGFMT_NV12:
+        *out_iformat = plane == 0 ? GL_R8 : GL_RG8;
+        *out_format = plane == 0 ? GL_RED : GL_RG;
+        *out_type = GL_UNSIGNED_BYTE;
+        return true;
+    case IMGFMT_P010:
+#ifdef IMGFMT_P016
+    case IMGFMT_P016:
+#endif
+        *out_iformat = plane == 0 ? GL_R16 : GL_RG16;
+        *out_format = plane == 0 ? GL_RED : GL_RG;
+        *out_type = GL_UNSIGNED_SHORT;
+        return true;
+    default:
+        return false;
+    }
+}
+
+static bool can_map_videotoolbox_direct(struct pl_video *p, const struct mp_image *mpi)
+{
+    if (!p || !mpi || mpi->imgfmt != IMGFMT_VIDEOTOOLBOX)
+        return false;
+
+    if (!pl_opengl_get(ra_get_gpu(p->ra)) || !CGLGetCurrentContext())
+        return false;
+
+    switch (mpi->params.hw_subfmt) {
+    case IMGFMT_NV12:
+    case IMGFMT_P010:
+#ifdef IMGFMT_P016
+    case IMGFMT_P016:
+#endif
+        return true;
+    default:
+        return false;
+    }
+}
+
+static void cleanup_videotoolbox_frame(struct pl_video *p, struct pl_frame *frame,
+                                       unsigned int textures[PL_MAX_PLANES],
+                                       int *num_textures, bool release_textures)
+{
+    if (!p || !num_textures)
+        return;
+
+    for (int n = 0; frame && n < frame->num_planes; n++) {
+        if (frame->planes[n].texture)
+            pl_tex_destroy(ra_get_gpu(p->ra), &frame->planes[n].texture);
+    }
+
+    if (release_textures && *num_textures > 0)
+        glDeleteTextures(*num_textures, textures);
+
+    if (release_textures) {
+        memset(textures, 0, sizeof(unsigned int) * PL_MAX_PLANES);
+        *num_textures = 0;
+    }
+}
+
+static bool map_videotoolbox_frame(struct pl_video *p, struct mp_image *mpi,
+                                   struct pl_frame *frame,
+                                   unsigned int textures[PL_MAX_PLANES],
+                                   int *num_textures)
+{
+    if (!can_map_videotoolbox_direct(p, mpi))
+        return false;
+
+    CVPixelBufferRef pbuf = (CVPixelBufferRef)mpi->planes[3];
+    if (!pbuf) {
+        mp_msg(p->log, MSGL_ERR, "gpu-next: missing CVPixelBuffer for VideoToolbox frame\n");
+        return false;
+    }
+
+    IOSurfaceRef surface = CVPixelBufferGetIOSurface(pbuf);
+    if (!surface) {
+        mp_msg(p->log, MSGL_ERR, "gpu-next: VideoToolbox frame has no IOSurface\n");
+        return false;
+    }
+
+    struct mp_image_params par = mpi->params;
+    par.imgfmt = par.hw_subfmt;
+    par.hw_subfmt = 0;
+    mp_image_params_guess_csp(&par);
+
+    init_frame_from_mpi(frame, mpi, &par);
+    fill_plane_component_mapping(frame, par.imgfmt);
+
+    const bool planar = CVPixelBufferIsPlanar(pbuf);
+    const int planes = planar ? CVPixelBufferGetPlaneCount(pbuf) : 1;
+    if (planes < frame->num_planes) {
+        mp_msg(p->log, MSGL_ERR, "gpu-next: unexpected VideoToolbox plane count %d for %s\n",
+               planes, mp_imgfmt_to_name(par.imgfmt));
+        return false;
+    }
+
+    if (*num_textures != frame->num_planes) {
+        if (*num_textures > 0) {
+            glDeleteTextures(*num_textures, textures);
+            memset(textures, 0, sizeof(unsigned int) * PL_MAX_PLANES);
+        }
+        glGenTextures(frame->num_planes, textures);
+        *num_textures = frame->num_planes;
+    }
+
+    for (int n = 0; n < frame->num_planes; n++) {
+        GLint iformat = 0;
+        GLenum format = 0;
+        GLenum type = 0;
+        if (!videotoolbox_subfmt_to_gl(par.imgfmt, n, &iformat, &format, &type)) {
+            mp_msg(p->log, MSGL_ERR, "gpu-next: unsupported VideoToolbox subfmt %s\n",
+                   mp_imgfmt_to_name(par.imgfmt));
+            goto error;
+        }
+
+        size_t width = planar ? CVPixelBufferGetWidthOfPlane(pbuf, n)
+                              : CVPixelBufferGetWidth(pbuf);
+        size_t height = planar ? CVPixelBufferGetHeightOfPlane(pbuf, n)
+                               : CVPixelBufferGetHeight(pbuf);
+
+        glBindTexture(GL_TEXTURE_RECTANGLE, textures[n]);
+        CGLError err = CGLTexImageIOSurface2D(CGLGetCurrentContext(),
+                                              GL_TEXTURE_RECTANGLE,
+                                              iformat,
+                                              width,
+                                              height,
+                                              format,
+                                              type,
+                                              surface,
+                                              planar ? n : 0);
+        glBindTexture(GL_TEXTURE_RECTANGLE, 0);
+
+        if (err != kCGLNoError) {
+            mp_msg(p->log, MSGL_ERR,
+                   "gpu-next: failed to import IOSurface plane %d: %s\n",
+                   n, CGLErrorString(err));
+            goto error;
+        }
+
+        frame->planes[n].texture = pl_opengl_wrap(
+            ra_get_gpu(p->ra),
+            pl_opengl_wrap_params(
+                .texture = textures[n],
+                .target = GL_TEXTURE_RECTANGLE,
+                .iformat = iformat,
+                .width = width,
+                .height = height));
+        if (!frame->planes[n].texture) {
+            mp_msg(p->log, MSGL_ERR,
+                   "gpu-next: failed to wrap imported IOSurface plane %d\n", n);
+            goto error;
+        }
+    }
+
+    return true;
+
+error:
+    cleanup_videotoolbox_frame(p, frame, textures, num_textures, true);
+    *frame = (struct pl_frame){0};
+    return false;
+}
+#endif
+
+/**
+ * @brief Callback to map an mp_image to a pl_frame for rendering.
+ *
+ * This function is called by the queue when it needs to prepare a frame for rendering.
+ * It handles uploading the image data from CPU memory to a GPU texture.
+ * @param gpu The libplacebo GPU handle.
+ * @param tex (unused) A pointer for an older API, not used here.
+ * @param src The source frame from the queue, containing the mp_image.
+ * @param frame The destination `pl_frame` to be populated with GPU texture info.
+ * @return True on success, false on failure.
+ */
+static bool map_frame(pl_gpu gpu, pl_tex *tex, const struct pl_source_frame *src,
+                      struct pl_frame *frame)
+{
+    struct mp_image *mpi = src ? src->frame_data : NULL;
+    struct frame_priv *fp = mpi ? mpi->priv : NULL;
+    struct pl_video *p = fp ? fp->p : NULL;
+    if (!mpi || !fp || !p)
+        return false;
+
+#if HAVE_GL && defined(PL_HAVE_OPENGL) && (HAVE_VIDEOTOOLBOX_GL || HAVE_IOS_GL)
+    if (mpi->imgfmt == IMGFMT_VIDEOTOOLBOX && !fp->vt_pool_entry)
+        fp->vt_pool_entry = acquire_vt_texture_pool_entry(p);
+
+    if (map_videotoolbox_frame(p, mpi, frame, fp->vt_pool_entry ? fp->vt_pool_entry->textures : fp->vt_textures,
+                               fp->vt_pool_entry ? &fp->vt_pool_entry->num_textures : &fp->vt_num_textures)) {
+        if (fp->vt_pool_entry) {
+            memcpy(fp->vt_textures, fp->vt_pool_entry->textures, sizeof(fp->vt_textures));
+            fp->vt_num_textures = fp->vt_pool_entry->num_textures;
+        }
+        fp->vt_mapped = true;
+        return true;
+    }
+
+    if (mpi->imgfmt == IMGFMT_VIDEOTOOLBOX) {
+        release_vt_texture_pool_entry(fp->vt_pool_entry);
+        fp->vt_pool_entry = NULL;
+        mp_msg(p->log, MSGL_WARN,
+               "gpu-next: direct VideoToolbox mapping failed, falling back to hw download\n");
+    }
+#endif
+
+    fp->mapped_image = download_hw_frame_for_upload(p, mpi);
+    if (!fp->mapped_image) {
+        talloc_free(mpi);
+        return false;
+    }
+
+    // Use the RA helper to upload the mp_image data to a new set of textures
+    // and populate the pl_frame struct with the result.
+    if (!ra_upload_mp_image(p->ra, frame, fp->mapped_image)) {
+        if (fp->mapped_image != mpi)
+            talloc_free(fp->mapped_image);
+        talloc_free(mpi); // Clean up the mp_image reference on failure
+        return false;
+    }
+
+    // Store a pointer back to the original mp_image. This is used to get a unique
+    // signature for the frame and to access metadata (like colorspace) later.
+    frame->user_data = fp->mapped_image;
+    return true;
+}
+
+/**
+ * @brief Callback to unmap a pl_frame after it has been rendered.
+ *
+ * This function is called by the queue to free the GPU resources associated
+ * with a frame that is no longer needed for rendering.
+ * @param gpu The libplacebo GPU handle.
+ * @param frame The `pl_frame` containing the GPU textures to be destroyed.
+ * @param src The source frame from the queue.
+ */
+static void unmap_frame(pl_gpu gpu, struct pl_frame *frame,
+                        const struct pl_source_frame *src)
+{
+    struct mp_image *mpi = src ? src->frame_data : NULL;
+    struct frame_priv *fp = mpi ? mpi->priv : NULL;
+    struct pl_video *p = fp ? fp->p : NULL;
+    if (!mpi || !fp || !p)
+        return;
+
+    // Use the RA helper to destroy the GPU textures associated with the frame.
+#if HAVE_GL && defined(PL_HAVE_OPENGL) && (HAVE_VIDEOTOOLBOX_GL || HAVE_IOS_GL)
+    if (fp->vt_mapped) {
+        cleanup_videotoolbox_frame(p, frame,
+                                   fp->vt_pool_entry ? fp->vt_pool_entry->textures : fp->vt_textures,
+                                   fp->vt_pool_entry ? &fp->vt_pool_entry->num_textures : &fp->vt_num_textures,
+                                   !fp->vt_pool_entry);
+        fp->vt_mapped = false;
+        release_vt_texture_pool_entry(fp->vt_pool_entry);
+        fp->vt_pool_entry = NULL;
+    } else
+#endif
+    {
+        ra_cleanup_pl_frame(p->ra, frame);
+    }
+    if (fp->mapped_image && fp->mapped_image != mpi)
+        talloc_free(fp->mapped_image);
+    // Free the mp_image reference itself.
+    talloc_free(mpi);
+}
+
+/**
+ * @brief Callback to discard a frame that was pushed into the queue but never rendered.
+ *
+ * This is called for frames that are dropped (e.g., due to performance issues).
+ * It frees the CPU-side mp_image without touching the GPU.
+ * @param src The source frame from the queue to be discarded.
+ */
+static void discard_frame(const struct pl_source_frame *src)
+{
+    // We only need to free the mp_image reference, as no GPU resources were created.
+    struct mp_image *mpi = src->frame_data;
+    struct frame_priv *fp = mpi ? mpi->priv : NULL;
+    if (fp && fp->mapped_image && fp->mapped_image != mpi)
+        talloc_free(fp->mapped_image);
+    talloc_free(mpi);
+}
+
+/**
+ * @brief Initializes the synchronous libplacebo rendering engine.
+ * @param global The mpv global context.
+ * @param log The logging context.
+ * @param ra The rendering abstraction context.
+ * @return A pointer to the newly created pl_video engine, or NULL on failure.
+ */
+struct pl_video *pl_video_init(struct mpv_global *global, struct mp_log *log, struct ra_next *ra) {
+    struct pl_video *p = talloc_zero(NULL, struct pl_video);
+    if (!p)
+        return NULL;
+    p->log = log;
+    p->ra = ra;
+    p->pllog = ra_get_pl_log(ra);
+    if (!p->ra) {
+        talloc_free(p);
+        return NULL;
+    }
+    p->queue = ra_next_queue_create(ra);
+    if (!p->queue) {
+        talloc_free(p);
+        return NULL;
+    }
+
+    // Pre-find the texture formats we'll need for OSD bitmaps for efficiency.
+    p->osd_fmt[SUBBITMAP_LIBASS] = ra_next_find_fmt(p->ra, PL_FMT_UNORM, 1, 8, 8, 0);
+    p->osd_fmt[SUBBITMAP_BGRA]   = ra_next_find_fmt(p->ra, PL_FMT_UNORM, 4, 8, 8, 0);
+
+    p->opts_cache = m_config_cache_alloc(p, global, &gl_video_conf);
+    p->pars = pl_options_alloc(p->pllog);
+    p->icc_params = pl_icc_default_params;
+    if (!p->opts_cache || !p->pars) {
+        ra_next_queue_destroy(&p->queue);
+        pl_options_free(&p->pars);
+        talloc_free(p);
+        return NULL;
+    }
+    update_render_options(p);
+
+    // Create the state object that tracks brightness, contrast, etc.
+    p->video_eq = mp_csp_equalizer_create(p, global);
+    if (!p->video_eq) {
+        ra_next_queue_destroy(&p->queue);
+        pl_options_free(&p->pars);
+        talloc_free(p);
+        return NULL;
+    }
+
+    return p;
+}
+
+/**
+ * @brief Shuts down and destroys the rendering engine and its resources.
+ * @param p_ptr A pointer to the pl_video engine pointer to be freed.
+ */
+void pl_video_uninit(struct pl_video **p_ptr) {
+    struct pl_video *p = *p_ptr;
+    if (!p) return;
+
+    ra_next_queue_destroy(&p->queue);
+
+    // Clean up all allocated OSD GPU resources
+    for (int i = 0; i < MP_ARRAY_SIZE(p->osd_state_storage.entries); i++) {
+        struct pl_video_osd_entry *entry = &p->osd_state_storage.entries[i];
+        ra_next_tex_destroy(p->ra, &entry->tex);
+        talloc_free(entry->parts);
+    }
+    for (int i = 0; i < p->num_sub_tex; i++) {
+        ra_next_tex_destroy(p->ra, &p->sub_tex[i]);
+    }
+    talloc_free(p->sub_tex);
+#if HAVE_GL && defined(PL_HAVE_OPENGL) && (HAVE_VIDEOTOOLBOX_GL || HAVE_IOS_GL)
+    for (int i = 0; i < p->num_vt_texture_pool; i++) {
+        if (p->vt_texture_pool[i].num_textures > 0)
+            glDeleteTextures(p->vt_texture_pool[i].num_textures,
+                             p->vt_texture_pool[i].textures);
+    }
+#endif
+    talloc_free(p->vt_texture_pool);
+    pl_icc_close(&p->icc_profile);
+    pl_options_free(&p->pars);
+
+    talloc_free(p);
+    *p_ptr = NULL;
+}
+
+/**
+ * @brief Updates the OSD overlays for the current video frame.
+ * @param p The pl_video context.
+ * @param res The OSD resolution.
+ * @param flags The OSD update flags.
+ * @param coords The overlay coordinates.
+ * @param state The current OSD state.
+ * @param frame The video frame to update.
+ * @param src The source image for the frame.
+ */
+static void update_overlays(struct pl_video *p, struct mp_osd_res res,
+                            int flags, enum pl_overlay_coords coords,
+                            struct pl_video_osd_state *state, struct pl_frame *frame,
+                            struct mp_image *src)
+{
+    frame->num_overlays = 0;
+    if (!p->current_osd_state)
+        return;
+
+    // Render the logical OSD state into a list of bitmaps.
+    double pts = src ? src->pts : 0;
+    struct sub_bitmap_list *subs = osd_render(p->current_osd_state, res, pts, flags, mp_draw_sub_formats);
+    if (!subs) return;
+
+    frame->overlays = state->overlays;
+
+    // Iterate through each bitmap and convert it into a libplacebo overlay.
+    for (int n = 0; n < subs->num_items; n++) {
+        const struct sub_bitmaps *item = subs->items[n];
+        if (!item->num_parts || !item->packed)
+            continue;
+
+        struct pl_video_osd_entry *entry = &state->entries[item->render_index];
+        pl_fmt tex_fmt = p->osd_fmt[item->format];
+
+        // Reuse a texture from the pool if available.
+        if (!entry->tex)
+            MP_TARRAY_POP(p->sub_tex, p->num_sub_tex, &entry->tex);
+
+        // Recreate the texture if its size needs to change.
+        bool ok = ra_next_tex_recreate(p->ra, &entry->tex, &(struct pl_tex_params) {
+            .format = tex_fmt,
+            .w = MPMAX(item->packed_w, entry->tex ? entry->tex->params.w : 0),
+            .h = MPMAX(item->packed_h, entry->tex ? entry->tex->params.h : 0),
+            .host_writable = true,
+            .sampleable = true,
+        });
+        if (!ok) {
+            mp_msg(p->log, MSGL_ERR, "Failed recreating OSD texture!\n");
+            break;
+        }
+
+        // Upload the new bitmap data to the GPU texture.
+        ok = ra_next_tex_upload(p->ra, &(struct pl_tex_transfer_params) {
+            .tex        = entry->tex,
+            .rc         = { .x1 = item->packed_w, .y1 = item->packed_h, },
+            .row_pitch  = item->packed->stride[0],
+            .ptr        = item->packed->planes[0],
+        });
+        if (!ok) {
+            mp_msg(p->log, MSGL_ERR, "Failed uploading OSD texture!\n");
+            break;
+        }
+
+        entry->num_parts = 0;
+        talloc_free(entry->parts);
+        entry->parts = talloc_array(p, struct pl_overlay_part, item->num_parts);
+
+        // Convert each sub-bitmap part into a pl_overlay_part.
+        for (int i = 0; i < item->num_parts; i++) {
+            const struct sub_bitmap *b = &item->parts[i];
+            if (b->dw == 0 || b->dh == 0)
+                continue;
+            uint32_t c = b->libass.color;
+            struct pl_overlay_part part = {
+                .src = { b->src_x, b->src_y, b->src_x + b->w, b->src_y + b->h },
+                .dst = { b->x, b->y, b->x + b->dw, b->y + b->dh },
+                .color = {
+                    (c >> 24) / 255.0f,
+                    ((c >> 16) & 0xFF) / 255.0f,
+                    ((c >> 8) & 0xFF) / 255.0f,
+                    (255 - (c & 0xFF)) / 255.0f,
+                }
+            };
+            entry->parts[entry->num_parts++] = part;
+        }
+
+        // Create the final pl_overlay structure for rendering.
+        struct pl_overlay *ol = &state->overlays[frame->num_overlays++];
+        *ol = (struct pl_overlay) {
+            .tex = entry->tex,
+            .parts = entry->parts,
+            .num_parts = entry->num_parts,
+            .color = { .primaries = PL_COLOR_PRIM_BT_709, .transfer = PL_COLOR_TRC_SRGB },
+            .coords = coords,
+        };
+
+        // Set blending modes based on the OSD bitmap format.
+        if (item->format == SUBBITMAP_BGRA) {
+            ol->mode = PL_OVERLAY_NORMAL;
+            ol->repr.alpha = PL_ALPHA_PREMULTIPLIED;
+            if (src) ol->color = src->params.color;
+        } else if (item->format == SUBBITMAP_LIBASS) {
+            ol->mode = PL_OVERLAY_MONOCHROME;
+            ol->repr.alpha = PL_ALPHA_INDEPENDENT;
+            if (src && item->video_color_space) ol->color = src->params.color;
+        }
+    }
+
+    talloc_free(subs);
+}
+
+/**
+ * @brief Main rendering function for a single video frame.
+ * @param p The pl_video engine context.
+ * @param frame The mpv frame to render, containing the current image.
+ * @param target_tex The destination GPU texture to render to.
+ * @param target_flip Whether the render target uses inverted Y coordinates.
+ */
+void pl_video_render(struct pl_video *p, struct vo_frame *frame, pl_tex target_tex,
+                     bool target_flip, int target_depth)
+{
+    if (!p || !p->ra || !p->queue || !target_tex)
+        return;
+    const struct gl_video_opts *opts = p->opts_cache->opts;
+    bool can_interpolate = frame && opts->interpolation && frame->display_synced &&
+                           !frame->still && frame->num_frames > 1;
+    // Describe the target surface for libplacebo.
+    struct pl_frame target_frame = {
+        .num_planes = 1,
+        .planes[0] = {
+            .texture = target_tex,
+            .components = 4,
+            .component_mapping = {0,1,2,3},
+            .flipped = target_flip,
+        },
+        .crop = { .x0 = p->current_dst.x0, .y0 = p->current_dst.y0, .x1 = p->current_dst.x1, .y1 = p->current_dst.y1 },
+        .repr = pl_color_repr_rgb,
+    };
+
+    // The libmpv VO provides one new frame at a time in frame->current.
+    // We check the frame_id to avoid pushing duplicates.
+    if (frame && frame->current) {
+        if (!p->want_reset && frame->frame_id < p->last_frame_id)
+            p->want_reset = true;
+        if (!p->want_reset && frame->current->pts + 1e-6 < p->last_pts)
+            p->want_reset = true;
+    }
+
+    if (p->want_reset)
+        force_render_reset(p, "timeline/config changed");
+
+    if (frame && frame->current && frame->frame_id > p->last_frame_id) {
+        struct mp_image *mpi = mp_image_new_ref(frame->current);
+        if (!mpi) {
+            mp_msg(p->log, MSGL_ERR, "Failed to reference current frame.\n");
+            return;
+        }
+        // Attach our private data to the image for the callbacks.
+        struct frame_priv *fp = talloc_zero(mpi, struct frame_priv);
+        if (!fp) {
+            mp_msg(p->log, MSGL_ERR, "Failed to allocate frame state.\n");
+            talloc_free(mpi);
+            return;
+        }
+        fp->p = p;
+        mpi->priv = fp;
+
+        // Push the frame into the queue with its callbacks.
+        ra_next_queue_push(p->queue, &(struct pl_source_frame) {
+            .pts = mpi->pts,
+            .frame_data = mpi,
+            .map = map_frame,
+            .unmap = unmap_frame,
+            .discard = discard_frame,
+        });
+
+        p->last_frame_id = frame->frame_id;
+    }
+
+    // If this is a redraw request, frame->current will be NULL. In that case,
+    // we reuse the last known PTS to query the queue for the correct frame.
+    double target_pts = (frame && frame->current) ? frame->current->pts : p->last_pts;
+    p->last_pts = target_pts;
+
+    struct pl_frame_mix queue_mix = {0};
+    struct pl_queue_params qparams = *pl_queue_params(
+        .pts = target_pts,
+        .radius = pl_frame_mix_radius(&p->pars->params),
+        .vsync_duration = can_interpolate ? frame->ideal_frame_vsync_duration : 0,
+        .interpolation_threshold = opts->interpolation_threshold
+    );
+#if PL_API_VER >= 340
+    qparams.drift_compensation = 0;
+#endif
+
+    ra_next_queue_update(p->queue, &queue_mix, &qparams);
+
+    // To render OSD, we need a representative source frame to get color space info.
+    // The first frame in the mix is a perfect candidate.
+    struct mp_image *representative_img = NULL;
+    if (queue_mix.num_frames > 0 && queue_mix.frames) {
+        representative_img = queue_mix.frames[0]->user_data;
+    }
+
+    update_render_options(p);
+    target_frame.color = get_default_libmpv_target_csp(p);
+    apply_target_options(p, &target_frame,
+                         representative_img ? representative_img->params.color.hdr.min_luma : 0.0f,
+                         target_depth);
+
+    const struct pl_color_space *source_csp = representative_img
+        ? &representative_img->params.color
+        : (p->current_params.imgfmt ? &p->current_params.color : NULL);
+    infer_target_map_from_source(&target_frame, source_csp);
+    if (source_csp && target_frame.color.transfer == PL_COLOR_TRC_SRGB &&
+        ((opts->sdr_adjust_gamma == 0 && opts->target_trc == PL_COLOR_TRC_UNKNOWN) ||
+         opts->sdr_adjust_gamma == -1))
+    {
+        switch (source_csp->transfer) {
+        case PL_COLOR_TRC_BT_1886:
+        case PL_COLOR_TRC_GAMMA22:
+        case PL_COLOR_TRC_SRGB:
+            target_frame.color.transfer = source_csp->transfer;
+            break;
+        default:
+            break;
+        }
+    }
+
+    // Manually build the final mix for the renderer, including the signatures.
+    // We need a local array to hold the signature data. 32 is a safe upper bound.
+    uint64_t signatures[32];
+    assert(queue_mix.num_frames < MP_ARRAY_SIZE(signatures));
+    for (int i = 0; i < queue_mix.num_frames; i++) {
+        // Use the mp_image pointer as a unique signature for caching.
+        signatures[i] = (uintptr_t)queue_mix.frames[i]->user_data;
+    }
+    struct pl_frame_mix mix = queue_mix;
+    mix.signatures = signatures;
+
+    // Generate and attach OSD overlays to the target frame. If mix.num_frames is 0,
+    // representative_img will be NULL, and update_overlays will correctly render
+    // OSD against a black background.
+    update_overlays(p, p->osd_res, 0, PL_OVERLAY_COORDS_DST_FRAME,
+                   &p->osd_state_storage, &target_frame, representative_img);
+
+    // Prepare the rendering parameters for libplacebo
+    struct pl_render_params params = p->pars->params;
+
+    // Declare a local struct to hold the color adjustment values.
+    struct pl_color_adjustment color_adj;
+
+    // Fill our local struct with the live equalizer values.
+    update_color_adjustment(p, &color_adj);
+
+    // Point the render params' pointer to our local struct.
+    params.color_adjustment = &color_adj;
+
+    // Render the mix. libplacebo handles the empty mix case (no video) correctly.
+    if (!ra_next_render_image_mix(p->ra, &mix, &target_frame, &params)) {
+        mp_msg(p->log, MSGL_ERR, "Rendering failed.\n");
+    }
+}
+
+ /**
+  * @brief Takes a screenshot of the current video frame.
+  * @param ctx The render_backend context.
+  * @param frame The video frame to capture.
+  * @param args The screenshot arguments.
+  */
+struct mp_image *pl_video_screenshot(struct pl_video *p, struct vo_frame *frame,
+                                     struct voctrl_screenshot *args)
+{
+    if (!p || !p->ra || !frame || !frame->current) {
+        if (p && p->log)
+            mp_msg(p->log, MSGL_WARN, "pl_video_screenshot: invalid arguments\n");
+        return NULL;
+    }
+
+    struct mp_image *res = NULL;
+    struct pl_frame source_frame = {0};
+    pl_tex fbo = NULL;
+    bool mapped_vt = false;
+    unsigned int vt_textures[PL_MAX_PLANES] = {0};
+    int vt_num_textures = 0;
+    struct mp_image *upload_img = frame->current;
+
+    // Upload the mp_image to a pl_frame via the RA helper.
+#if HAVE_GL && defined(PL_HAVE_OPENGL) && (HAVE_VIDEOTOOLBOX_GL || HAVE_IOS_GL)
+    if (map_videotoolbox_frame(p, frame->current, &source_frame,
+                               vt_textures, &vt_num_textures)) {
+        mapped_vt = true;
+    } else
+#endif
+    {
+        upload_img = download_hw_frame_for_upload(p, frame->current);
+    }
+    if (!mapped_vt && (!upload_img || !ra_upload_mp_image(p->ra, &source_frame, upload_img))) {
+        mp_msg(p->log, MSGL_ERR, "pl_video_screenshot: failed to prepare source image\n");
+        if (upload_img && upload_img != frame->current)
+            talloc_free(upload_img);
+        return NULL;
+    }
+
+    int w = frame->current->w;
+    int h = frame->current->h;
+    struct mp_osd_res osd_res = {
+        .w = w,
+        .h = h,
+        .display_par = 1.0,
+    };
+
+    if (args && args->scaled && p->osd_res.w > 0 && p->osd_res.h > 0) {
+        w = p->osd_res.w;
+        h = p->osd_res.h;
+        osd_res = p->osd_res;
+    }
+
+    int mpfmt = IMGFMT_RGBA;
+    pl_fmt fbo_fmt = NULL;
+    int requested_depth = args && args->high_bit_depth ? 16 : 8;
+    for (int depth = requested_depth; depth >= 8; depth -= 8) {
+        fbo_fmt = ra_next_find_fmt(p->ra, PL_FMT_UNORM, 4, depth, depth,
+                                   PL_FMT_CAP_RENDERABLE | PL_FMT_CAP_HOST_READABLE);
+        if (!fbo_fmt)
+            continue;
+        mpfmt = depth > 8 ? IMGFMT_RGBA64 : IMGFMT_RGBA;
+        fbo = ra_next_tex_create(p->ra, pl_tex_params(
+            .w = w,
+            .h = h,
+            .format = fbo_fmt,
+            .renderable = true,
+            .host_readable = true
+        ));
+        if (fbo)
+            break;
+    }
+    if (!fbo) {
+        mp_msg(p->log, MSGL_ERR, "pl_video_screenshot: failed to create temporary texture\n");
+        goto done;
+    }
+
+    update_render_options(p);
+
+    struct pl_frame target_frame = {
+        .num_planes = 1,
+        .planes[0] = {
+            .texture = fbo,
+            .components = 4,
+            .component_mapping = {0, 1, 2, 3},
+        },
+        .repr = pl_color_repr_rgb,
+    };
+
+    target_frame.color = get_default_libmpv_target_csp(p);
+    apply_target_options(p, &target_frame, frame->current->params.color.hdr.min_luma,
+                         requested_depth);
+
+    const struct gl_video_opts *opts = p->opts_cache->opts;
+    const struct pl_color_space *source_csp = &frame->current->params.color;
+    if (args && args->native_csp && !pl_color_space_is_hdr(source_csp))
+        target_frame.color = *source_csp;
+
+    infer_target_map_from_source(&target_frame, source_csp);
+
+    if (source_csp && target_frame.color.transfer == PL_COLOR_TRC_SRGB &&
+        ((opts->sdr_adjust_gamma == 0 && opts->target_trc == PL_COLOR_TRC_UNKNOWN) ||
+         opts->sdr_adjust_gamma == -1))
+    {
+        switch (source_csp->transfer) {
+        case PL_COLOR_TRC_BT_1886:
+        case PL_COLOR_TRC_GAMMA22:
+        case PL_COLOR_TRC_SRGB:
+            target_frame.color.transfer = source_csp->transfer;
+            break;
+        default:
+            break;
+        }
+    }
+
+    int osd_flags = 0;
+    if (args && !args->subs)
+        osd_flags |= OSD_DRAW_OSD_ONLY;
+    if (args && !args->osd)
+        osd_flags |= OSD_DRAW_SUB_ONLY;
+
+    update_overlays(p, osd_res, osd_flags, PL_OVERLAY_COORDS_DST_FRAME,
+                    &p->osd_state_storage, &target_frame, frame->current);
+
+    struct pl_render_params params = p->pars->params;
+    params.info_callback = NULL;
+    params.skip_caching_single_frame = true;
+    params.preserve_mixing_cache = false;
+    params.frame_mixer = NULL;
+    struct pl_peak_detect_params peak_params;
+    if (params.peak_detect_params) {
+        peak_params = *params.peak_detect_params;
+        params.peak_detect_params = &peak_params;
+        peak_params.allow_delayed = false;
+    }
+    struct pl_color_adjustment color_adj = {0};
+    update_color_adjustment(p, &color_adj);
+    params.color_adjustment = &color_adj;
+
+    if (!ra_next_render_image(p->ra, &source_frame, &target_frame, &params)) {
+        mp_msg(p->log, MSGL_ERR, "pl_video_screenshot: rendering failed\n");
+        goto done;
+    }
+
+    res = mp_image_alloc(mpfmt, w, h);
+    if (!res) {
+        mp_msg(p->log, MSGL_ERR, "pl_video_screenshot: failed to allocate mp_image\n");
+        goto done;
+    }
+
+    res->params.color.primaries = target_frame.color.primaries;
+    res->params.color.transfer = target_frame.color.transfer;
+    res->params.repr.levels = target_frame.repr.levels;
+    res->params.color.hdr = target_frame.color.hdr;
+    res->params.light = pl_color_transfer_is_hdr(target_frame.color.transfer)
+        ? (target_frame.color.transfer == PL_COLOR_TRC_HLG ? MP_CSP_LIGHT_SCENE_HLG
+                                                           : MP_CSP_LIGHT_DISPLAY)
+        : MP_CSP_LIGHT_DISPLAY;
+
+    bool ok = ra_next_tex_download(p->ra, &(struct pl_tex_transfer_params){
+        .tex = fbo,
+        .ptr = res->planes[0],
+        .row_pitch = res->stride[0],
+    });
+
+    if (!ok) {
+        mp_msg(p->log, MSGL_ERR, "pl_video_screenshot: texture download failed\n");
+        talloc_free(res);
+        res = NULL;
+        goto done;
+    }
+
+done:
+    if (fbo)
+        ra_next_tex_destroy(p->ra, &fbo);
+
+#if HAVE_GL && defined(PL_HAVE_OPENGL) && (HAVE_VIDEOTOOLBOX_GL || HAVE_IOS_GL)
+    if (mapped_vt) {
+        cleanup_videotoolbox_frame(p, &source_frame, vt_textures, &vt_num_textures, true);
+    } else
+#endif
+    {
+        ra_cleanup_pl_frame(p->ra, &source_frame);
+    }
+
+    if (upload_img && upload_img != frame->current)
+        talloc_free(upload_img);
+
+    return res;
+}
+
+/**
+ * @brief Informs the engine that the video parameters have changed.
+ * @param p The pl_video engine context.
+ * @param params The new image parameters.
+ */
+void pl_video_reconfig(struct pl_video *p, const struct mp_image_params *params) {
+    if (params)
+        p->current_params = *params;
+    p->want_reset = true;
+}
+
+/**
+ * @brief Informs the engine that the output viewport has been resized.
+ * @param p The pl_video engine context.
+ * @param dst The new destination rectangle.
+ * @param osd The new OSD resolution information.
+ */
+void pl_video_resize(struct pl_video *p, const struct mp_rect *dst, const struct mp_osd_res *osd) {
+    if (dst)
+        p->current_dst = *dst;
+    if (osd)
+        p->osd_res = *osd;
+}
+
+/**
+ * @brief Provides the engine with the current On-Screen Display state.
+ * @param p The pl_video engine context.
+ * @param osd A pointer to the current OSD state.
+ */
+void pl_video_update_osd(struct pl_video *p, struct osd_state *osd) {
+    p->current_osd_state = osd;
+}
+
+/**
+ * @brief Informs the engine that it should flush internal caches.
+ * @param p The pl_video engine context.
+ */
+void pl_video_reset(struct pl_video *p) {
+    if (!p || !p->ra) return;
+    force_render_reset(p, "explicit reset");
+}
+
+/**
+ * @brief Asks the engine if a specific image format is supported.
+ * @param p The pl_video engine context.
+ * @param imgfmt The image format to check.
+ * @return True if the format is likely supported, false otherwise.
+ */
+bool pl_video_check_format(struct pl_video *p, int imgfmt) {
+    // For simplicity, we assume libplacebo can handle it.
+    // A more robust implementation might query libplacebo's capabilities.
+    return true;
+}
