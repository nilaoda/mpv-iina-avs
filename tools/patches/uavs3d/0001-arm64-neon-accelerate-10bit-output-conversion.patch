 #if defined(__arm64__)
 
+static void uavs3d_conv_fmt_16bit_neon(u8 *src_y, u8 *src_uv, u8 *dst[3], int width, int height,
+                                       int src_stride, int src_stridec, int dst_stride[3], int uv_shift)
+{
+    int i, j;
+    int width_bytes = width << 1;
+    int src_stride_y = src_stride >> 1;
+    int src_stride_uv = src_stridec >> 1;
+    int dst_stride_y = dst_stride[0] >> 1;
+    int dst_stride_u = dst_stride[1] >> 1;
+    int dst_stride_v = dst_stride[2] >> 1;
+    u16 *src_y_row = (u16 *)src_y;
+    u16 *dst_y_row = (u16 *)dst[0];
+    u16 *src_uv_row;
+    u16 *dst_u_row;
+    u16 *dst_v_row;
+
+    for (i = 0; i < height; i++) {
+        memcpy(dst_y_row, src_y_row, width_bytes);
+        src_y_row += src_stride_y;
+        dst_y_row += dst_stride_y;
+    }
+
+    width >>= uv_shift;
+    height >>= uv_shift;
+
+    src_uv_row = (u16 *)src_uv;
+    dst_u_row = (u16 *)dst[1];
+    dst_v_row = (u16 *)dst[2];
+    for (i = 0; i < height; i++) {
+        u16 *src_uv_ptr = src_uv_row;
+        u16 *dst_u_ptr = dst_u_row;
+        u16 *dst_v_ptr = dst_v_row;
+
+        for (j = 0; j + 8 <= width; j += 8) {
+            uint16x8x2_t uv = vld2q_u16(src_uv_ptr);
+            vst1q_u16(dst_u_ptr, uv.val[0]);
+            vst1q_u16(dst_v_ptr, uv.val[1]);
+            src_uv_ptr += 16;
+            dst_u_ptr += 8;
+            dst_v_ptr += 8;
+        }
+        for (; j < width; j++) {
+            *dst_u_ptr++ = *src_uv_ptr++;
+            *dst_v_ptr++ = *src_uv_ptr++;
+        }
+
+        src_uv_row += src_stride_uv;
+        dst_u_row += dst_stride_u;
+        dst_v_row += dst_stride_v;
+    }
+}
