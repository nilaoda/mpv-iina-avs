+static uavs3d_always_inline int mc_ref_line_luma(int qpel_y, int height, int max_posy)
+{
+    int y_pos = COM_CLIP3(-MAX_CU_SIZE - 4, max_posy, qpel_y >> 2);
+    return y_pos + height + 4;
+}
+
+static uavs3d_always_inline int mc_ref_line_chroma(int qpel_y, int height, int max_posy)
+{
+    int y_pos = COM_CLIP3(-(MAX_CU_SIZE >> 1) - 2, max_posy, qpel_y >> 3);
+    return ((y_pos + height) << 1) + 4;
+}
+
+static uavs3d_always_inline void mc_check_ref_ready(com_pic_t *ref_pic, int qpel_gmv_y, int h, int tree_status, int max_posy)
+{
+    int line_num;
+
+    if (tree_status == TREE_C) {
+        line_num = mc_ref_line_chroma(qpel_gmv_y, h >> 1, max_posy >> 1);
+    } else if (tree_status == TREE_L) {
+        line_num = mc_ref_line_luma(qpel_gmv_y, h, max_posy);
+    } else {
+        int line_luma = mc_ref_line_luma(qpel_gmv_y, h, max_posy);
+        int line_chroma = mc_ref_line_chroma(qpel_gmv_y, h >> 1, max_posy >> 1);
+        line_num = COM_MAX(line_luma, line_chroma);
+    }
+
+    uavs3d_check_ref_avaliable(ref_pic, line_num);
+}
